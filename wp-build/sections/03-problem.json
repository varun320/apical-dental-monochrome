          "id": "w03a02",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "Implant dentistry is still bottlenecked by a handful of surgeons.",
            "header_size": "h2",
            "typography_typography": "custom",
            "typography_font_family": "Fraunces",
            "typography_font_size":        { "unit": "rem", "size": 2.75 },
            "typography_font_size_tablet": { "unit": "rem", "size": 2.25 },
            "typography_font_size_mobile": { "unit": "rem", "size": 1.65 },
            "typography_font_weight": "400",
            "typography_line_height": { "unit": "em", "size": 1.1 },
            "typography_letter_spacing":        { "unit": "px", "size": -1 },
            "typography_letter_spacing_mobile": { "unit": "px", "size": -0.3 },
            "title_color": "#1A1A1C",
            "_animation": "fadeInUp",
            "_animation_delay": 100
          }
        }
      ]
    },
    {
      "id": "col03b",
      "elType": "column",
      "settings": { "_column_size": 58, "_inline_size_tablet": 100, "space_between_widgets": { "unit": "px", "size": 28 } },
      "elements": [
        {
          "id": "w03b01",
          "elType": "widget",
          "widgetType": "text-editor",
          "settings": {
            "editor": "<p>General practices refer out every complex implant case. DSOs lose 30–40% of specialty revenue to outside networks. Patients wait weeks for a chair that a robot-guided system could fill in ninety minutes.</p><p style=\"margin-top:16px\"><strong style=\"font-weight:500\">Apical closes that gap.</strong> A supervised robotic platform, shared across your network, lets every practice deliver specialist-grade surgery without hiring one.</p>",
            "typography_typography": "custom",
            "typography_font_family": "Inter",
            "typography_font_size": { "unit": "rem", "size": 1.0625 },
            "typography_font_weight": "400",
            "typography_line_height": { "unit": "em", "size": 1.65 },
            "text_color": "#1A1A1C",
            "_animation": "fadeInUp",
            "_animation_delay": 200
          }
        },
        {
          "id": "w03b02",
          "elType": "widget",
          "widgetType": "text-editor",
          "settings": {
            "editor": "<div style=\"display:flex;flex-wrap:wrap;gap:24px;padding-top:24px;border-top:1px solid rgba(26,26,28,0.15);font-family:Inter;font-size:13px;font-weight:500;letter-spacing:0.5px\"><div style=\"display:flex;align-items:center;gap:10px\"><span style=\"display:inline-block;width:6px;height:6px;border-radius:50%;background:#B85C3C\"></span>8,000 specialists · 200M patients</div><div style=\"display:flex;align-items:center;gap:10px\"><span style=\"display:inline-block;width:6px;height:6px;border-radius:50%;background:#B85C3C\"></span>40% of complex cases refer out</div><div style=\"display:flex;align-items:center;gap:10px\"><span style=\"display:inline-block;width:6px;height:6px;border-radius:50%;background:#B85C3C\"></span>Half-day surgical blocks wasted</div></div>",
            "_animation": "fadeInUp",
            "_animation_delay": 300
          }
        }
      ]
    }
  ]
