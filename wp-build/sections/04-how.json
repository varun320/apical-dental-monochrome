{
  "id": "sec04how",
  "elType": "section",
  "isInner": false,
  "settings": {
    "layout": "boxed",
    "content_width": { "unit": "px", "size": 1320 },
    "padding":        { "unit": "px", "top": "140", "right": "40", "bottom": "140", "left": "40", "isLinked": false },
    "padding_tablet": { "unit": "px", "top": "96",  "right": "32", "bottom": "96",  "left": "32", "isLinked": false },
    "padding_mobile": { "unit": "px", "top": "72",  "right": "22", "bottom": "72",  "left": "22", "isLinked": false },
    "background_background": "classic",
    "background_color": "#F3EEE5"
  },
  "elements": [
    {
      "id": "colhow",
      "elType": "column",
      "settings": { "_column_size": 100, "space_between_widgets": { "unit": "px", "size": 48 } },
      "elements": [
        {
          "id": "whow01",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "02 — HOW IT WORKS",
            "header_size": "h6",
            "typography_typography": "custom",
            "typography_font_family": "Inter",
            "typography_font_size": { "unit": "px", "size": 12 },
            "typography_font_weight": "500",
            "typography_letter_spacing": { "unit": "px", "size": 2 },
            "typography_text_transform": "uppercase",
            "title_color": "#1A1A1C",
            "_animation": "fadeInUp",
            "_margin": { "unit": "px", "top": "0", "right": "0", "bottom": "12", "left": "0", "isLinked": false }
          }
        },
        {
          "id": "whow02",
          "elType": "widget",
          "widgetType": "heading",
          "settings": {
            "title": "From scan to restoration in ninety minutes.",
            "header_size": "h2",
            "typography_typography": "custom",
            "typography_font_family": "Fraunces",
            "typography_font_size":        { "unit": "rem", "size": 3 },
            "typography_font_size_tablet": { "unit": "rem", "size": 2.25 },
            "typography_font_size_mobile": { "unit": "rem", "size": 1.75 },
            "typography_font_weight": "400",
            "typography_line_height": { "unit": "em", "size": 1.1 },
            "typography_letter_spacing":        { "unit": "px", "size": -1 },
            "typography_letter_spacing_mobile": { "unit": "px", "size": -0.3 },
            "title_color": "#1A1A1C",
            "_animation": "fadeInUp",
            "_animation_delay": 100,
            "_element_custom_width": { "unit": "%", "size": 70 },
            "_element_custom_width_tablet": { "unit": "%", "size": 100 }
          }
        },
        {
          "id": "whow03",
          "elType": "widget",
          "widgetType": "text-editor",
          "settings": {
            "editor": "<div style=\"display:grid;grid-template-columns:repeat(3,minmax(0,1fr));gap:56px;font-family:Inter;margin-top:24px\"><div style=\"border-top:1px solid rgba(26,26,28,0.2);padding-top:28px\"><div style=\"font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(26,26,28,0.5);margin-bottom:20px\">Step 01</div><div style=\"color:#1A1A1C;font-size:28px;margin-bottom:16px\">&#128247;</div><h3 style=\"font-family:Fraunces;font-size:1.65rem;font-weight:400;letter-spacing:-0.5px;color:#1A1A1C;margin:0 0 12px\">Scan &amp; plan</h3><p style=\"font-size:15px;line-height:1.6;color:rgba(26,26,28,0.75);margin:0\">Intraoral scan plus a cone-beam CT feed our planning AI. Surgical trajectory ready in under five minutes.</p></div><div style=\"border-top:1px solid rgba(26,26,28,0.2);padding-top:28px\"><div style=\"font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(26,26,28,0.5);margin-bottom:20px\">Step 02</div><div style=\"color:#B85C3C;font-size:28px;margin-bottom:16px\">&#129302;</div><h3 style=\"font-family:Fraunces;font-size:1.65rem;font-weight:400;letter-spacing:-0.5px;color:#1A1A1C;margin:0 0 12px\">Robot-guided surgery</h3><p style=\"font-size:15px;line-height:1.6;color:rgba(26,26,28,0.75);margin:0\">Haptic-feedback arm places the implant to sub-millimetre accuracy, supervised by a remote specialist on your team.</p></div><div style=\"border-top:1px solid rgba(26,26,28,0.2);padding-top:28px\"><div style=\"font-size:11px;font-weight:500;letter-spacing:2px;text-transform:uppercase;color:rgba(26,26,28,0.5);margin-bottom:20px\">Step 03</div><div style=\"color:#1A1A1C;font-size:28px;margin-bottom:16px\">&#129463;</div><h3 style=\"font-family:Fraunces;font-size:1.65rem;font-weight:400;letter-spacing:-0.5px;color:#1A1A1C;margin:0 0 12px\">Same-day restoration</h3><p style=\"font-size:15px;line-height:1.6;color:rgba(26,26,28,0.75);margin:0\">Chairside crown milling and temporary placement before the patient leaves — no second visit required.</p></div></div><style>@media (max-width:768px){[data-id=\"whow03\"] > div > div > div { display:block !important; } [data-id=\"whow03\"] > div { grid-template-columns:1fr !important; gap:32px !important; }}</style>",
            "_animation": "fadeInUp",
            "_animation_delay": 200
          }
        }
      ]
    }
  ]
}
